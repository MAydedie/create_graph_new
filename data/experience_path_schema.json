            },
            "io_summary": {
              "input": [
                "输入1"
              ],
              "output": [
                "输出1"
              ]
            },
            "input_info": {},
            "output_info": {},
            "cfg": "可选：CFG 数据或引用",
            "dfg": "可选：DFG 数据或引用",
            "io_graph": "可选：IO 图数据",
